APP_NAME="Digital Kotor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Samo za eksplicitni provisioning: php artisan db:seed --class=SuperAdminSeeder
# Ne koristiti obični php artisan db:seed na produkciji (povlači demo seedere).
# Poslije uspješnog seeda ukloniti SUPERADMIN_PASSWORD iz produkcijskog .env i ponovo config:cache.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Package 2A / 2C — Document Library archive
# Produkcija može imati EXTERNAL_ARCHIVE_LIBRARY_UPLOAD=true
# Default u example ostaje false (siguran clone). Ne uključivati DELETE_LOCAL bez odobrenja.
EXTERNAL_ARCHIVE_LIBRARY_UPLOAD=false

# Ostale Package 1 archive varijable
EXTERNAL_ARCHIVE_PROVIDER=mega
EXTERNAL_ARCHIVE_DELETE_LOCAL_AFTER_UPLOAD=false

# Package 2D — Document Library limits & smart PDF (Imagick)
DOCUMENT_LIBRARY_IMAGE_MAX_KB=2048
DOCUMENT_LIBRARY_PDF_MAX_KB=20480
DOCUMENT_LIBRARY_USER_QUOTA_BYTES=20971520
DOCUMENT_LIBRARY_PDF_OPTIMIZATION_THRESHOLD_BYTES=3145728
DOCUMENT_LIBRARY_PDF_TARGET_DPI=200
DOCUMENT_LIBRARY_PDF_GRAYSCALE=true
DOCUMENT_LIBRARY_PDF_JPEG_QUALITY=82
# Produkcija shared hosting (provjereno): upload_max_filesize=2M, post_max_size=8M, memory_limit=128M
# — Default, neizmjenjivo iz Plesk panela. Zatražiti od provajdera 25M / 32M za PDF do 20 MB.
# Aplikacioni DOCUMENT_LIBRARY_PDF_MAX_KB=20480 ostaje; efektivno na produkciji 2M dok se limiti ne povećaju.
# Automatsko lokalno brisanje nakon arhive ostaje isključeno (DELETE_LOCAL=false).
# Produkcijski .env se ne mijenja zbog PHP Settings.
