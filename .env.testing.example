# Šablon testnog okruženja — kopirati u .env.testing i popuniti lokalne vrijednosti:
#   cp .env.testing.example .env.testing
#   php artisan key:generate --env=testing
# .env.testing je u .gitignore i ne commit-uje se.

APP_NAME="Digital Kotor"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Testovi zahtijevaju MySQL bazu čiji naziv sadrži "test" ili "testing"
# (guard u tests/TestCase.php prekida izvršavanje u suprotnom).
# Nikada ne koristiti razvojnu ni produkcijsku bazu.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=opstinakotor_digital_testing
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=array
MAIL_MAILER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
